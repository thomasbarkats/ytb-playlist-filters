{
  "name": "ytb-playlist-filters",
  "version": "1.1.2",
  "description": "Enhance your YouTube Watch Later and other playlists experience with search and filtering capabilities.",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "watch": "webpack --config webpack.config.js --watch",
    "package": "npm run build && bestzip package.zip package/*",
    "commit": "format-commit"
  },
  "author": "Thomas BARKATS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasbarkats/ytb-playlist-filters"
  },
  "keywords": [
    "youtube",
    "playlist",
    "filter",
    "search",
    "chrome-extension",
    "youtube-playlist"
  ],
  "bugs": {
    "url": "https://github.com/thomasbarkats/ytb-playlist-filters/issues"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@types/chrome": "^0.1.43",
    "babel-loader": "^10.1.1",
    "bestzip": "^3.0.1",
    "copy-webpack-plugin": "^14.0.0",
    "format-commit": "^1.1.0",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "overrides": {
    "@babel/preset-modules": {
      "@babel/core": "$@babel/core"
    }
  }
}
